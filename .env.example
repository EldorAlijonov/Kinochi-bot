BOT_TOKEN=your-telegram-bot-token
# TOKEN eski nom bilan ham qo'llab-quvvatlanadi, yangi deploylarda BOT_TOKEN ishlating.
TOKEN=
ADMINS=123456789
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telegram_bot
DB_USER=postgres
DB_PASSWORD=postgres
# DATABASE_URL berilsa DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD ustidan ishlatiladi.
DATABASE_URL=
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO
APP_ENV=development
SUBSCRIPTION_CACHE_TTL_SECONDS=30
SUBSCRIPTION_STATUS_CACHE_TTL_SECONDS=60
PENDING_MOVIE_TTL_SECONDS=1800
AUTO_INIT_DB=true
RATE_LIMIT_WINDOW_SECONDS=10
RATE_LIMIT_MAX_REQUESTS=8
BASE_WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=change-me-in-production
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
WEBHOOK_MAX_CONNECTIONS=40
WEBHOOK_SETUP_RETRIES=3
WEBHOOK_DROP_PENDING_UPDATES=false
DELETE_WEBHOOK_ON_SHUTDOWN=false
BOT_REQUEST_TIMEOUT=30
